{
  "name": "react-app",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "scripts": {
    "start:development": "vite --mode development",
    "build:development": "yarn eslint && vite build --mode development",
    "start:test": "vite --mode test",
    "build:test": "yarn eslint && vite build --mode test",
    "start:production": "vite --mode production",
    "build:production": "yarn eslint && vite build --mode production",
    "analyze": "cross-env ANALYZE=true vite build --mode production",
    "eslint": "cross-env NODE_ENV=production eslint --fix ./src",
    "preview": "vite preview",
    "clear:package": "rm -rf ./node_modules && rm -rf dist && rm -rf coverage",
    "init:package": "yarn clear:package && yarn install",
    "clear:cache": "rm -rf ./node_modules/.vite",
    "init:cusenv": "node ./customEnv.js",
    "ncu:check": "ncu --target minor -f 'antd,@ant-design/icons,@ant-design/cssinjs,ahooks'",
    "ncu:update": "ncu --target minor -u -f 'antd,@ant-design/icons,@ant-design/cssinjs,ahooks' && yarn install"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router": "5.1.20",
    "@types/react-router-dom": "5.3.3",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "autoprefixer": "10.4.21",
    "cross-env": "7.0.3",
    "dayjs": "^1.11.13",
    "eslint": "8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fs-extra": "10.1.0",
    "less": "4.3.0",
    "moment": "^2.30.1",
    "postcss": "8.5.6",
    "postcss-flexbugs-fixes": "5.0.2",
    "postcss-preset-env": "7.8.3",
    "rc-picker": "^4.11.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^6",
    "recorder-core": "^1.3.25011100",
    "sass": "1.89.0",
    "semver": "7.7.2",
    "serve": "14.2.4",
    "styled-components": "^6.3.12",
    "typescript": "5.1.6",
    "web-vitals": "1.1.2"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.1.1",
    "@types/lodash": "4.17.20",
    "@types/qs": "6.14.0",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "ahooks": "3.9.7",
    "antd": "^6.3.5",
    "await-to-js": "3.0.0",
    "axios": "0.30.1",
    "axios-mock-adapter": "1.22.0",
    "babel-plugin-styled-components": "^2.1.4",
    "lodash": "4.17.21",
    "qs": "6.14.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "3.4.17",
    "terser": "^5.47.1",
    "vite": "^8.0.12",
    "vite-plugin-svgr": "^5.2.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "yarn": ">=1.22.0"
  }
}
